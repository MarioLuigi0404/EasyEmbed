{
    "video_remux": {
        "c:v": "copy"
    },
    "video_transcode": {
        "c:v": "libx264",
        "preset":"fast",
        "crf": "18"
    },
    "audio_remux": {
        "c:a": "copy"
    },
    "audio_transcode": {
